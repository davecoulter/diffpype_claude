VOL_APP=<local root directory of the code repository>
VOL_APP_IO=<local directory for file IO>
VOL_DB=<local root directory of the database files>
VOL_DB_LOG=<local root directory of the database log files. Make separate from the VOL_DB.>
VOL_DB_RUN=<local root directory of the database runtime files. Make separate from the VOL_DB and VOL_DB_LOG>
DB_PWD=<Root password for the database service>
LOCAL_DB_PORT=<Local port to mount to container database service>
CPU_LIMIT=<How many CPUs to allocate for a service>
MEM_LIMIT=<How much RAM to allocate for a service in GBs>
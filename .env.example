POSTGRES_USER=diffpype
POSTGRES_PASSWORD=diffpype
POSTGRES_DB=diffpype
POSTGRES_PORT=5432

REDIS_PORT=6379

API_PORT=8000

UI_PORT=5173
VITE_API_URL=http://localhost:8000

FLOWER_PORT=5555
PORTAINER_PORT=9000

TEST_DATABASE_URL=postgresql+psycopg2://diffpype:diffpype@db:5432/diffpype_test

# Application logging level (consumed by pydantic-settings -> src/core/config.py)
LOG_LEVEL=INFO

# Celery worker resource tuning
CELERY_LIGHT_CONCURRENCY=4
CELERY_LIGHT_MAX_MEMORY_PER_CHILD=200000
WORKER_LIGHT_MEM_LIMIT=512m

CELERY_HEAVY_CONCURRENCY=1
CELERY_HEAVY_MAX_MEMORY_PER_CHILD=8000000
WORKER_HEAVY_MEM_LIMIT=8g

# Admin & security (see doc 20 — set real values in .env and GitHub Actions secrets)
ADMIN_USER=sysadmin
ADMIN_PASSWORD=changeme
ADMIN_SECRET_KEY=diffpype-dev-secret-key-change-in-production
FLOWER_BASIC_AUTH=admin:changeme
CORS_ORIGINS=http://localhost:5173,http://0.0.0.0:5173

# Celery task reliability (see doc 21)
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_DELAY=60
ENABLE_DB_BACKUP_CRON=false
